# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/transport_pass_system
# Example Atlas URI:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/transport_pass_system?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=replace_with_a_long_random_secret_key
JWT_EXPIRE=7d

# File Upload Configuration
MAX_FILE_SIZE=5000000
UPLOAD_PATH=./uploads

# CORS Configuration
FRONTEND_URL=http://localhost:3000
